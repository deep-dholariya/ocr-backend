# =============================================================================
# ENVIRONMENT CONFIGURATION
# Copy this file to `.env` and fill in real values.
# See README.md -> "Environment Variables" for a full explanation of each.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=5000

# Public URL this server is reachable at. Used for logging only.
# localhost:   http://localhost:5000
# LAN/mobile:  http://<your-pc-lan-ip>:5000
# ngrok:       https://<your-subdomain>.ngrok-free.dev
# Render:      https://<your-app>.onrender.com
SERVER_URL=http://localhost:5000

# The frontend origin this API accepts requests/cookies from.
# This is ALWAYS allowed by CORS. LAN IPs, ngrok, and *.onrender.com are
# auto-allowed too (see src/config/cors.js) — you normally only need to
# change this one value when switching environments.
CLIENT_URL=http://localhost:3000

# Optional: comma-separated list of EXTRA exact origins to allow, for
# frontend URLs that don't match the CLIENT_URL / auto-detected patterns.
# EXTRA_ALLOWED_ORIGINS=https://my-custom-frontend.example.com

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://127.0.0.1:27017/business-card-app

# -----------------------------------------------------------------------------
# Google OAuth 2.0
# -----------------------------------------------------------------------------
# Register ALL of these as "Authorized redirect URIs" in Google Cloud Console
# at once — it's fine to have all four registered simultaneously:
#   http://localhost:5000/api/auth/google/callback
#   http://<lan-ip>:5000/api/auth/google/callback           (only if testing OAuth over LAN HTTP; many providers reject non-HTTPS here)
#   https://<your-subdomain>.ngrok-free.dev/api/auth/google/callback
#   https://<your-app>.onrender.com/api/auth/google/callback
# Then just set GOOGLE_CALLBACK_URL below to whichever one matches how
# you're currently running the server — no code changes needed.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# Use long, random, unguessable strings in production (e.g. `openssl rand -hex 64`)
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# -----------------------------------------------------------------------------
# Cookies
# -----------------------------------------------------------------------------
# Set to your top-level domain in production, e.g. .example.com, ONLY if the
# frontend and API share a parent domain. Leave blank for localhost/LAN/ngrok
# and for Render deployments where frontend/API are on different domains.
COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# Python OCR Service (separate Render service)
# -----------------------------------------------------------------------------
# Base URL of the standalone Python OCR service. No trailing slash.
# localhost:   http://localhost:5001
# Render:      https://<your-python-ocr-service>.onrender.com
PYTHON_API_URL=http://localhost:5001

# Hard timeout (ms) for a single OCR request before it's aborted and
# retried once. Prevents a stuck PaddleOCR call from hanging a request
# forever.
OCR_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
# Directory where uploaded business card images are stored (relative to
# the project root, or an absolute path).
UPLOAD_DIR=uploads

# Maximum upload file size in bytes. 10485760 = 10 MB.
MAX_FILE_SIZE=10485760
